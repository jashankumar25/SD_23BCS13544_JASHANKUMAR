        {
          "name": "Rate Limit — Request 6 (429 TOO MANY REQUESTS !!!)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/recommendations?type=popularity",
              "host": ["{{BASE_URL}}"],
              "path": ["recommendations"],
              "query": [{ "key": "type", "value": "popularity" }]
            },
            "description": "Request 6 of 6 — RATE LIMIT HIT!\n\nExpected Response:\n- Status: 429 Too Many Requests\n- Body: { \"status\": 429, \"error\": \"Too Many Requests\", \"message\": \"You have exceeded the 5 requests per minute limit.\" }"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rate limit triggered - 429', () => pm.response.to.have.status(429));",
                  "pm.test('Error message correct', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.error).to.eql('Too Many Requests');",
                  "  console.log('Rate limit message:', json.message);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
